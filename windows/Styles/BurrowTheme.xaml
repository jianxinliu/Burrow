<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="BurrowColorBackground">#121217</Color>
    <Color x:Key="BurrowColorBackgroundGreen">#0C1B16</Color>
    <Color x:Key="BurrowColorBackgroundBlue">#0B1620</Color>
    <Color x:Key="BurrowColorBackgroundBrown">#1A120C</Color>
    <Color x:Key="BurrowColorBackgroundPurple">#11101F</Color>
    <Color x:Key="BurrowColorPanel">#1D1D22</Color>
    <Color x:Key="BurrowColorPanelWarm">#221C16</Color>
    <Color x:Key="BurrowColorStroke">#343238</Color>
    <Color x:Key="BurrowColorText">#F3ECDD</Color>
    <Color x:Key="BurrowColorMuted">#B5AEA2</Color>
    <Color x:Key="BurrowColorDim">#807A72</Color>
    <Color x:Key="BurrowColorAccent">#D9A066</Color>
    <Color x:Key="BurrowColorOnAccent">#241B12</Color>
    <Color x:Key="BurrowColorGreen">#57D58E</Color>
    <Color x:Key="BurrowColorGold">#E6A93C</Color>
    <Color x:Key="BurrowColorOrange">#F2894E</Color>
    <Color x:Key="BurrowColorBlue">#5AA8F0</Color>
    <Color x:Key="BurrowColorRed">#F0604E</Color>
    <Color x:Key="BurrowColorPurple">#8E84F0</Color>

    <SolidColorBrush x:Key="BurrowBackgroundBrush" Color="{StaticResource BurrowColorBackground}" />
    <SolidColorBrush x:Key="BurrowBackgroundGreenBrush" Color="{StaticResource BurrowColorBackgroundGreen}" />
    <SolidColorBrush x:Key="BurrowBackgroundBlueBrush" Color="{StaticResource BurrowColorBackgroundBlue}" />
    <SolidColorBrush x:Key="BurrowBackgroundBrownBrush" Color="{StaticResource BurrowColorBackgroundBrown}" />
    <SolidColorBrush x:Key="BurrowBackgroundPurpleBrush" Color="{StaticResource BurrowColorBackgroundPurple}" />
    <SolidColorBrush x:Key="BurrowPanelBrush" Color="{StaticResource BurrowColorPanel}" />
    <SolidColorBrush x:Key="BurrowPanelWarmBrush" Color="{StaticResource BurrowColorPanelWarm}" />
    <SolidColorBrush x:Key="BurrowStrokeBrush" Color="{StaticResource BurrowColorStroke}" />
    <SolidColorBrush x:Key="BurrowTextBrush" Color="{StaticResource BurrowColorText}" />
    <SolidColorBrush x:Key="BurrowMutedBrush" Color="{StaticResource BurrowColorMuted}" />
    <SolidColorBrush x:Key="BurrowDimBrush" Color="{StaticResource BurrowColorDim}" />
    <SolidColorBrush x:Key="BurrowAccentBrush" Color="{StaticResource BurrowColorAccent}" />
    <SolidColorBrush x:Key="BurrowOnAccentBrush" Color="{StaticResource BurrowColorOnAccent}" />
    <SolidColorBrush x:Key="BurrowGreenBrush" Color="{StaticResource BurrowColorGreen}" />
    <SolidColorBrush x:Key="BurrowGoldBrush" Color="{StaticResource BurrowColorGold}" />
    <SolidColorBrush x:Key="BurrowOrangeBrush" Color="{StaticResource BurrowColorOrange}" />
    <SolidColorBrush x:Key="BurrowBlueBrush" Color="{StaticResource BurrowColorBlue}" />
    <SolidColorBrush x:Key="BurrowRedBrush" Color="{StaticResource BurrowColorRed}" />
    <SolidColorBrush x:Key="BurrowPurpleBrush" Color="{StaticResource BurrowColorPurple}" />
    <SolidColorBrush x:Key="BurrowWhitePillBrush" Color="#FFFDF8" />

    <FontFamily x:Key="BurrowTextFont">ms-appx:///Assets/Fonts/Geist[wght].woff2#Geist, Segoe UI</FontFamily>
    <FontFamily x:Key="BurrowMonoFont">ms-appx:///Assets/Fonts/GeistMono[wght].woff2#Geist Mono, Consolas</FontFamily>
    <FontFamily x:Key="BurrowSerifFont">ms-appx:///Assets/Fonts/CalSans-SemiBold.woff2#Cal Sans, Segoe UI</FontFamily>

    <Style x:Key="TitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BurrowSerifFont}" />
        <Setter Property="FontSize" Value="42" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BurrowTextBrush}" />
    </Style>

    <Style x:Key="SubtitleTextBlockStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BurrowMonoFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BurrowMutedBrush}" />
    </Style>

    <Style x:Key="BurrowLabelTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource BurrowMonoFont}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CharacterSpacing" Value="80" />
        <Setter Property="Foreground" Value="{StaticResource BurrowMutedBrush}" />
    </Style>

    <Style x:Key="BurrowMetricTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="34" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource BurrowTextBrush}" />
    </Style>

    <Style x:Key="BurrowCardBorderStyle" TargetType="Border">
        <Setter Property="Padding" Value="20" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Background" Value="{StaticResource BurrowPanelBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BurrowStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style x:Key="BurrowPillButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="44" />
        <Setter Property="Padding" Value="24,8" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="FontFamily" Value="{StaticResource BurrowMonoFont}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Background" Value="{StaticResource BurrowWhitePillBrush}" />
        <Setter Property="Foreground" Value="Black" />
        <Setter Property="BorderBrush" Value="{StaticResource BurrowWhitePillBrush}" />
    </Style>

    <Style x:Key="BurrowSecondaryPillButtonStyle" TargetType="Button" BasedOn="{StaticResource BurrowPillButtonStyle}">
        <Setter Property="Background" Value="{StaticResource BurrowPanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource BurrowTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BurrowStrokeBrush}" />
    </Style>

    <Style x:Key="BurrowTopNavButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="42" />
        <Setter Property="Padding" Value="18,6" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="FontFamily" Value="{StaticResource BurrowMonoFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BurrowMutedBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style x:Key="BurrowTopNavButtonSelectedStyle" TargetType="Button" BasedOn="{StaticResource BurrowTopNavButtonStyle}">
        <Setter Property="Background" Value="{StaticResource BurrowWhitePillBrush}" />
        <Setter Property="Foreground" Value="Black" />
    </Style>

    <Style x:Key="BurrowIconButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="42" />
        <Setter Property="Height" Value="42" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="21" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BurrowMutedBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style x:Key="BurrowIconButtonSelectedStyle" TargetType="Button" BasedOn="{StaticResource BurrowIconButtonStyle}">
        <Setter Property="Background" Value="{StaticResource BurrowWhitePillBrush}" />
        <Setter Property="Foreground" Value="Black" />
    </Style>

    <Style TargetType="Page">
        <Setter Property="Background" Value="{StaticResource BurrowBackgroundBrush}" />
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource BurrowTextBrush}" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="Background" Value="#141412" />
        <Setter Property="Foreground" Value="{StaticResource BurrowTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BurrowStrokeBrush}" />
        <Setter Property="FontFamily" Value="{StaticResource BurrowMonoFont}" />
    </Style>

    <Style TargetType="ListView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource BurrowTextBrush}" />
    </Style>

    <Style TargetType="TreeView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BurrowTextBrush}" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{StaticResource BurrowGreenBrush}" />
        <Setter Property="Background" Value="#343331" />
        <Setter Property="MinHeight" Value="8" />
        <Setter Property="CornerRadius" Value="5" />
    </Style>
</ResourceDictionary>
